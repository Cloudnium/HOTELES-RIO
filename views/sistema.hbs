<!-- Sistema de Gestión Hotelera - Hoteles Rio v5 -->
<div id="sistema-app">

  <!-- ══ LOGIN ══ -->
  <div id="login-screen" class="login-screen">
    <div class="login-card">
      <div class="login-brand">
        <img src="/images/logos/logo.png" alt="Hoteles Rio" class="login-logo-img">
        <h2>Sistema de Gestión</h2>
        <p>Acceso exclusivo para personal autorizado</p>
      </div>
      <div class="login-form">
        <div class="login-field">
          <label>Correo electrónico</label>
          <div class="input-icon-wrap">
            <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input type="email" id="login-email" placeholder="tu@hotelrio.com" autocomplete="email">
          </div>
        </div>
        <div class="login-field">
          <label>Contraseña</label>
          <div class="input-icon-wrap">
            <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            <input type="password" id="login-pass" placeholder="••••••••" autocomplete="current-password">
          </div>
        </div>
        <div id="login-error" class="login-error" style="display:none"></div>
        <button id="login-btn" class="login-submit">
          <span id="login-btn-text">Ingresar al Sistema</span>
          <svg id="login-spinner" viewBox="0 0 24 24" style="display:none" class="spin" width="18" height="18"><circle cx="12" cy="12" r="10" fill="none" stroke="#fff" stroke-width="2.5" stroke-dasharray="32" stroke-dashoffset="8"/></svg>
        </button>
      </div>
      <div class="login-footer-note">
        <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        Conexión segura — Solo personal autorizado
      </div>
    </div>
  </div>

  <!-- ══ DASHBOARD ══ -->
  <div id="dashboard" class="dashboard" style="display:none">

    <!-- Sidebar -->
    <aside class="sys-sidebar" id="sys-sidebar">
      <div class="sys-brand">
        <div class="sys-brand-icon">
          <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div>
          <span class="sys-brand-name">Hoteles Rio</span>
          <span class="sys-brand-sub">Sistema Interno</span>
        </div>
      </div>

      <nav class="sys-nav">
        <div class="sys-nav-group">Principal</div>
        <a class="sys-nav-item active" data-sec="habitaciones">
          <i class="fas fa-bed fa-fw"></i> Habitaciones
        </a>
        <a class="sys-nav-item" data-sec="reservas-web">
          <i class="fas fa-calendar-check fa-fw"></i> Reservas Web
        </a>
        <a class="sys-nav-item" data-sec="tienda-hab">
          <i class="fas fa-concierge-bell fa-fw"></i> Tienda x Habitación
        </a>
        <a class="sys-nav-item" data-sec="tienda-publica">
          <i class="fas fa-shopping-cart fa-fw"></i> Tienda Pública
        </a>

        <div class="sys-nav-group">Inventario</div>
        <a class="sys-nav-item" data-sec="almacen">
          <i class="fas fa-boxes fa-fw"></i> Almacén
        </a>

        <div class="sys-nav-group">Finanzas</div>
        <a class="sys-nav-item" data-sec="cajas">
          <i class="fas fa-cash-register fa-fw"></i> Cajas del Día
        </a>
        <a class="sys-nav-item" data-sec="egresos">
          <i class="fas fa-arrow-circle-down fa-fw"></i> Egresos
        </a>
        <a class="sys-nav-item" data-sec="reportes">
          <i class="fas fa-chart-bar fa-fw"></i> Reportes
        </a>
        <a class="sys-nav-item" data-sec="comprobantes">
          <i class="fas fa-file-invoice fa-fw"></i> Comprobantes
        </a>

        <div class="sys-nav-group">Administración</div>
        <a class="sys-nav-item" data-sec="clientes">
          <i class="fas fa-users fa-fw"></i> Clientes
        </a>
        <a class="sys-nav-item" data-sec="comentarios">
          <i class="fas fa-comments fa-fw"></i> Comentarios
        </a>
        <a class="sys-nav-item" data-sec="usuarios">
          <i class="fas fa-user-cog fa-fw"></i> Usuarios
        </a>
      </nav>

      <div class="sys-user-card">
        <div class="sys-avatar" id="sys-avatar">U</div>
        <div class="sys-user-info">
          <span id="sys-user-name">Usuario</span>
          <small id="sys-user-role">—</small>
        </div>
        <button class="sys-logout" id="sys-logout" title="Cerrar sesión">
          <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        </button>
      </div>
    </aside>

    <!-- Main -->
    <div class="sys-main">
      <header class="sys-topbar">
        <div class="sys-topbar-left">
          <button class="sys-menu-toggle" id="sys-menu-toggle">
            <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <h1 id="sys-section-title">Habitaciones</h1>
        </div>
        <div class="sys-topbar-right">
          <button class="notif-btn" id="notif-btn" onclick="toggleNotifPanel()" title="Notificaciones">
            <i class="fas fa-bell"></i>
            <span class="notif-badge" id="notif-badge" style="display:none">0</span>
          </button>
          <div id="caja-status-topbar" class="caja-status-topbar cerrada">
            <span class="dot"></span>
            <span id="caja-status-text">Sin caja</span>
          </div>
          <span id="sys-date-badge" class="sys-date-badge"></span>
          <a href="/" class="btn-inicio-web" title="Ir al inicio del Hotel">
            <i class="fas fa-hotel"></i>
          </a>
        </div>
        <!-- Panel notificaciones -->
        <div id="notif-panel" class="notif-panel" style="display:none">
          <div class="notif-panel-head">
            <h4>Notificaciones</h4>
            <button onclick="marcarTodasLeidas()" class="sys-btn sys-btn-outline sys-btn-sm">Marcar leídas</button>
          </div>
          <div id="notif-list" class="notif-list"><div class="notif-empty">Sin notificaciones</div></div>
        </div>
      </header>

      <div class="sys-content">

        <!-- ═══ HABITACIONES ═══ -->
        <section id="sec-habitaciones" class="sys-section active">
          <div class="sec-toolbar">
            <div class="sec-toolbar-left">
              <select id="filter-piso" class="sys-select" style="display:none"><option value="">Todos los pisos</option></select>
              <select id="filter-estado" class="sys-select">
                <option value="">Todos los estados</option>
                <option value="disponible">Disponible</option>
                <option value="ocupado">Ocupado</option>
                <option value="limpieza">Limpieza</option>
                <option value="mantenimiento">Mantenimiento</option>
                <option value="reservado">Reservado</option>
              </select>
            </div>
            <div class="sec-toolbar-right" style="display:flex;align-items:center;gap:10px">
              <button class="sys-btn sys-btn-gold sys-btn-sm" id="btn-nueva-hab-admin" onclick="abrirModalNuevaHab()" style="display:none">
                <i class="fas fa-plus"></i> Nueva hab.
              </button>
              <div class="legend-dots">
                <span class="dot dot-verde"></span>Disponible
                <span class="dot dot-rojo"></span>Ocupado
                <span class="dot dot-celeste"></span>Limpieza
                <span class="dot dot-amarillo"></span>Mantenimiento
                <span class="dot dot-naranja"></span>Reservado
              </div>
            </div>
          </div>
          <div id="rooms-grid" class="rooms-grid-sys"></div>
        </section>

        <!-- ═══ RESERVAS WEB ═══ -->
        <section id="sec-reservas-web" class="sys-section">
          <div class="sec-toolbar">
            <div class="sec-toolbar-left">
              <select id="filter-reserva-estado" class="sys-select">
                <option value="">Todos los estados</option>
                <option value="pendiente">Pendiente</option>
                <option value="confirmada">Confirmada</option>
                <option value="cancelada">Cancelada</option>
              </select>
              <input type="date" class="sys-input" id="filter-reserva-fecha">
            </div>
          </div>
          <div class="stats-row-sys" id="reservas-stats"></div>
          <div class="sys-card">
            <div class="table-wrap"><table>
              <thead><tr><th>Fecha</th><th>Hora Llegada</th><th>Cliente</th><th>DNI</th><th>Teléfono</th><th>Habitación</th><th>Huésp.</th><th>Estado</th><th>Recibida</th><th>Acciones</th></tr></thead>
              <tbody id="reservas-table"><tr><td colspan="10" class="empty-row">Cargando reservas...</td></tr></tbody>
            </table></div>
          </div>
        </section>

        <!-- ═══ TIENDA x HABITACIÓN ═══ -->
        <section id="sec-tienda-hab" class="sys-section">
          <div class="sec-toolbar">
            <select id="sel-hab-tienda" class="sys-select" style="min-width:240px">
              <option value="">Seleccionar habitación ocupada...</option>
            </select>
          </div>
          <div class="two-col-layout">
            <div class="sys-card">
              <div class="sys-card-head"><h3><i class="fas fa-list-ul" style="color:var(--primary);margin-right:6px"></i>Consumos de la habitación</h3></div>
              <div class="table-wrap"><table>
                <thead><tr><th>Producto</th><th>Cant.</th><th>Precio</th><th>Total</th><th>Hora</th><th></th></tr></thead>
                <tbody id="consumos-hab-list"><tr><td colspan="6" class="empty-row">Selecciona una habitación ocupada</td></tr></tbody>
              </table></div>
              <div class="sys-card-foot">
                <span>Total habitación:</span>
                <strong id="total-consumos-hab">S/. 0.00</strong>
              </div>
            </div>
            <div class="sys-card">
              <div class="sys-card-head"><h3><i class="fas fa-shopping-bag" style="color:var(--primary);margin-right:6px"></i>Productos disponibles</h3></div>
              <div class="products-quick-grid" id="products-quick"></div>
            </div>
          </div>
        </section>

        <!-- ═══ TIENDA PÚBLICA ═══ -->
        <section id="sec-tienda-publica" class="sys-section">
          <div class="tienda-pub-layout">
            <!-- Catálogo -->
            <div class="catalogo-section">
              <div class="sys-card">
                <div class="sys-card-head">
                  <h3><i class="fas fa-store" style="color:var(--primary);margin-right:6px"></i>Catálogo de Productos</h3>
                  <span id="ventas-hoy-count" class="total-badge">0 ventas hoy</span>
                </div>
                <div style="padding:14px 14px 0">
                  <div class="catalogo-search-bar">
                    <input type="text" class="sys-input" id="search-product-pub" placeholder="🔍 Buscar producto...">
                    <select id="filter-cat-pub" class="sys-select">
                      <option value="">Todas las categorías</option>
                      <option value="bebidas">Bebidas</option>
                      <option value="snacks">Snacks/Alimentos</option>
                      <option value="higiene">Higiene</option>
                      <option value="servicios">Servicios</option>
                      <option value="otros">Otros</option>
                    </select>
                  </div>
                </div>
                <div class="productos-grid" id="products-catalog" style="padding:14px"></div>
              </div>
              <!-- Ventas del día -->
              <div class="sys-card">
                <div class="sys-card-head"><h3><i class="fas fa-history" style="color:var(--primary);margin-right:6px"></i>Ventas de hoy</h3></div>
                <div class="table-wrap"><table>
                  <thead><tr><th>Hora</th><th>Productos</th><th>Total</th><th>Cajero</th></tr></thead>
                  <tbody id="ventas-pub-list"><tr><td colspan="4" class="empty-row">Sin ventas hoy</td></tr></tbody>
                </table></div>
              </div>
            </div>

            <!-- Carrito -->
            <div class="carrito-section" id="carrito-section">
              <div class="carrito-header">
                <h3><i class="fas fa-shopping-cart" style="color:var(--primary)"></i> Carrito <span class="carrito-badge" id="carrito-count">0</span></h3>
                <button class="sys-btn sys-btn-outline sys-btn-sm" id="btn-limpiar-carrito">Limpiar</button>
              </div>
              <div class="carrito-items" id="carrito-items">
                <div class="carrito-empty">
                  <i class="fas fa-shopping-basket"></i>
                  <p style="font-size:13px;font-weight:500;color:var(--text-2)">Carrito vacío</p>
                  <p style="font-size:11px;color:var(--text-3);margin-top:4px">Haz clic en un producto para agregarlo</p>
                </div>
              </div>
              <div class="carrito-footer">
                <div class="carrito-total-row">
                  <span class="carrito-total-label">Total a cobrar</span>
                  <span class="carrito-total-val" id="carrito-total">S/. 0.00</span>
                </div>
                <button class="carrito-btn-cobrar" id="btn-confirmar-venta-pub">
                  <i class="fas fa-cash-register"></i> Cobrar
                </button>
                <button class="carrito-btn-limpiar" id="btn-nueva-venta-pub">Limpiar carrito</button>
              </div>
            </div>
          </div>
        </section>

        <!-- ═══ ALMACÉN ═══ -->
        <section id="sec-almacen" class="sys-section">
          <div class="sec-toolbar">
            <h2 style="font-size:15px;font-weight:700;color:var(--text-1)">Inventario de productos</h2>
            <button class="sys-btn sys-btn-gold" id="btn-add-product">
              <i class="fas fa-plus"></i> Nuevo producto
            </button>
          </div>
          <div class="stats-row-sys" id="almacen-stats"></div>
          <div class="sys-card">
            <div class="table-wrap"><table>
              <thead><tr><th>Código</th><th>Producto</th><th>Categoría</th><th>Precio Venta</th><th>Stock</th><th>Alerta mínima</th><th>Estado</th><th>Acciones</th></tr></thead>
              <tbody id="products-table"><tr><td colspan="8" class="empty-row">Cargando productos...</td></tr></tbody>
            </table></div>
          </div>
        </section>

        <!-- ═══ CAJAS ═══ -->
        <section id="sec-cajas" class="sys-section">
          <div class="sec-toolbar">
            <div class="sec-toolbar-left">
              <label style="font-size:11px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.5px">Fecha</label>
              <input type="date" class="sys-input" id="caja-hist-fecha">
              <span id="caja-fecha" style="font-size:14px;font-weight:600;color:var(--text-1)"></span>
            </div>
            <button class="sys-btn sys-btn-gold" id="btn-abrir-caja">
              <i class="fas fa-lock-open"></i> Abrir mi caja
            </button>
          </div>
          <div id="cajas-grid" class="cajas-grid"></div>
          <div class="sys-card">
            <div class="sys-card-head"><h3><i class="fas fa-list" style="color:var(--primary);margin-right:6px"></i>Movimientos</h3></div>
            <div class="table-wrap"><table>
              <thead><tr><th>Hora</th><th>Concepto</th><th>Tipo</th><th>Monto</th></tr></thead>
              <tbody id="caja-movimientos"><tr><td colspan="4" class="empty-row">Sin movimientos</td></tr></tbody>
            </table></div>
          </div>
        </section>

        <!-- ═══ EGRESOS ═══ -->
        <section id="sec-egresos" class="sys-section">
          <div class="sec-toolbar">
            <div class="sec-toolbar-left">
              <input type="date" class="sys-input" id="egreso-filtro-fecha">
              <select id="egreso-filtro-cat" class="sys-select">
                <option value="">Todas las categorías</option>
                <option value="compra">Compra de insumos</option>
                <option value="servicio">Servicio / Pago terceros</option>
                <option value="personal">Pago a personal</option>
                <option value="mantenimiento">Mantenimiento</option>
                <option value="otros">Otros gastos</option>
              </select>
            </div>
            <button class="sys-btn sys-btn-gold" id="btn-nuevo-egreso">
              <i class="fas fa-plus"></i> Nuevo egreso
            </button>
          </div>
          <div class="stats-row-sys" id="egresos-stats"></div>
          <div class="sys-card">
            <div class="sys-card-head"><h3><i class="fas fa-arrow-down" style="color:var(--danger);margin-right:6px"></i>Registro de Egresos</h3></div>
            <div class="table-wrap"><table>
              <thead><tr><th>Fecha</th><th>Categoría</th><th>Proveedor / Descripción</th><th>N° Doc.</th><th>Tipo Doc.</th><th>Monto</th><th>Acciones</th></tr></thead>
              <tbody id="egresos-table"><tr><td colspan="7" class="empty-row">Cargando...</td></tr></tbody>
            </table></div>
          </div>
        </section>

        <!-- ═══ REPORTES — Auto por fecha ═══ -->
        <section id="sec-reportes" class="sys-section">
          <!-- Filtro de fechas -->
          <div class="rep-fecha-bar">
            <div class="date-filter-group">
              <label>Desde</label>
              <input type="date" class="sys-input" id="reporte-desde">
              <label>Hasta</label>
              <input type="date" class="sys-input" id="reporte-hasta">
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
              <span id="rep-periodo-label" class="rep-periodo-label"></span>
              <button class="sys-btn sys-btn-outline" onclick="descargarReportePDF()" id="btn-pdf-reporte">
                <i class="fas fa-file-pdf"></i> Descargar PDF
              </button>
            </div>
          </div>

          <!-- Fila 1: KPIs de habitaciones -->
          <div class="rep-kpi-grid" id="rep-kpi-habs">
            <div class="rep-kpi-card rep-kpi-blue">
              <div class="rep-kpi-body"><span class="rep-kpi-val" id="rep-tot-habs">—</span><span class="rep-kpi-lbl">Total habitaciones</span></div>
              <i class="fas fa-building rep-kpi-icon"></i>
            </div>
            <div class="rep-kpi-card rep-kpi-green">
              <div class="rep-kpi-body"><span class="rep-kpi-val" id="rep-disponibles">—</span><span class="rep-kpi-lbl">Disponibles</span></div>
              <i class="fas fa-door-open rep-kpi-icon"></i>
            </div>
            <div class="rep-kpi-card rep-kpi-red">
              <div class="rep-kpi-body"><span class="rep-kpi-val" id="rep-ocupadas">—</span><span class="rep-kpi-lbl">Ocupadas</span></div>
              <i class="fas fa-door-closed rep-kpi-icon"></i>
            </div>
            <div class="rep-kpi-card rep-kpi-yellow">
              <div class="rep-kpi-body"><span class="rep-kpi-val" id="rep-mant">—</span><span class="rep-kpi-lbl">En mantenimiento</span></div>
              <i class="fas fa-tools rep-kpi-icon"></i>
            </div>
            <div class="rep-kpi-card rep-kpi-purple">
              <div class="rep-kpi-body"><span class="rep-kpi-val" id="rep-reservas-hoy">—</span><span class="rep-kpi-lbl">Reservas del período</span></div>
              <i class="fas fa-concierge-bell rep-kpi-icon"></i>
            </div>
            <div class="rep-kpi-card rep-kpi-gold">
              <div class="rep-kpi-body"><span class="rep-kpi-val" id="rep-checkouts-periodo">—</span><span class="rep-kpi-lbl">Check-outs del período</span></div>
              <i class="fas fa-folder-open rep-kpi-icon"></i>
            </div>
          </div>

          <!-- Fila 2: KPIs financieros -->
          <div class="rep-financiero-grid">
            <div class="rep-fin-card rep-fin-total">
              <div class="rep-fin-icon"><i class="fas fa-money-bill-wave"></i></div>
              <div><div class="rep-fin-label">TOTAL GENERAL</div><div class="rep-fin-val" id="rep-total-general">S/. 0.00</div></div>
            </div>
            <div class="rep-fin-card rep-fin-efectivo">
              <div class="rep-fin-icon"><i class="fas fa-money-bill"></i></div>
              <div><div class="rep-fin-label">EFECTIVO</div><div class="rep-fin-val" id="rep-efectivo">S/. 0.00</div><div class="rep-fin-sub">por método</div></div>
            </div>
            <div class="rep-fin-card rep-fin-digital">
              <div class="rep-fin-icon"><i class="fas fa-credit-card"></i></div>
              <div><div class="rep-fin-label">OTROS MÉTODOS</div><div class="rep-fin-val" id="rep-otros">S/. 0.00</div><div class="rep-fin-sub">Tarjeta / Yape / Plin</div></div>
            </div>
            <div class="rep-fin-card rep-fin-checkouts">
              <div class="rep-fin-icon"><i class="fas fa-check-double"></i></div>
              <div><div class="rep-fin-label">Check-outs completados</div><div class="rep-fin-val" id="rep-co-completados">0</div></div>
            </div>
            <div class="rep-fin-card rep-fin-tienda">
              <div class="rep-fin-icon"><i class="fas fa-store"></i></div>
              <div><div class="rep-fin-label">Ventas tienda pública</div><div class="rep-fin-val" id="rep-ventas-count">0 VENTAS</div><div class="rep-fin-sub" id="rep-ventas-sub">S/. 0.00</div></div>
            </div>
            <div class="rep-fin-card rep-fin-egresos">
              <div class="rep-fin-icon"><i class="fas fa-arrow-down"></i></div>
              <div><div class="rep-fin-label">Egresos del período</div><div class="rep-fin-val" id="rep-egresos-val">S/. 0.00</div></div>
            </div>
          </div>

          <!-- Fila 3: Tablas detalle -->
          <div class="two-col-layout">
            <div class="sys-card">
              <div class="sys-card-head">
                <h3><i class="fas fa-bed" style="color:var(--primary);margin-right:6px"></i>Ingresos por Habitaciones + Consumos</h3>
              </div>
              <div class="table-wrap"><table>
                <thead><tr><th>Habitación</th><th>Usos</th><th>Total</th></tr></thead>
                <tbody id="reporte-habitaciones"><tr><td colspan="3" class="empty-row">Cargando...</td></tr></tbody>
              </table></div>
            </div>
            <div class="sys-card">
              <div class="sys-card-head">
                <h3><i class="fas fa-shopping-cart" style="color:var(--primary);margin-right:6px"></i>Ingresos Tienda Pública</h3>
              </div>
              <div class="table-wrap"><table>
