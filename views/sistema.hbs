    <div class="sys-modal-body">
      <div class="form-grid-2">
        <div class="form-field"><label>Fecha</label>
          <input type="date" id="eg-fecha" class="sys-input"></div>
        <div class="form-field"><label>Categoría</label>
          <select id="eg-categoria" class="sys-select">
            <option value="compra">Compra de insumos</option>
            <option value="servicio">Servicio / Pago terceros</option>
            <option value="personal">Pago a personal</option>
            <option value="mantenimiento">Mantenimiento</option>
            <option value="otros">Otros gastos</option>
          </select></div>
        <div class="form-field form-field-full"><label>Descripción / Concepto</label>
          <input type="text" id="eg-descripcion" class="sys-input" placeholder="Ej: Compra de productos de limpieza"></div>
        <div class="form-field"><label>Proveedor / A nombre de</label>
          <input type="text" id="eg-proveedor" class="sys-input" placeholder="Ej: Distribuidora XYZ"></div>
        <div class="form-field"><label>Monto (S/.)</label>
          <input type="number" id="eg-monto" class="sys-input" placeholder="0.00" step="0.01" min="0"></div>
        <div class="form-field"><label>Tipo de documento</label>
          <select id="eg-tipo-doc" class="sys-select">
            <option value="boleta">Boleta</option>
            <option value="factura">Factura</option>
            <option value="recibo">Recibo</option>
            <option value="sin_doc">Sin documento</option>
          </select></div>
        <div class="form-field"><label>N° de documento</label>
          <input type="text" id="eg-num-doc" class="sys-input" placeholder="Ej: B001-00123"></div>
        <div class="form-field form-field-full"><label>Observaciones</label>
          <textarea id="eg-obs" class="sys-input" rows="2" placeholder="Notas adicionales..."></textarea></div>
        <input type="hidden" id="eg-id">
      </div>
      <div class="form-actions">
        <button class="sys-btn sys-btn-outline" data-modal="modal-egreso">Cancelar</button>
        <button class="sys-btn sys-btn-red" id="btn-guardar-egreso"><i class="fas fa-save"></i> Guardar egreso</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal alerta stock bajo -->
<div id="modal-stock-alert" class="sys-modal" style="display:none">
  <div class="sys-modal-box stock-alert-box">
    <div class="stock-alert-header">
      <span class="stock-alert-icon-title">
        <i class="fas fa-bullhorn"></i> Alerta
      </span>
    </div>
    <div class="sys-modal-body stock-alert-body">
      <h2 class="stock-alert-title">¡Productos en inventario<br>por debajo del stock óptimo!</h2>
      <div class="stock-alert-shelf">
       <img src="/images/not-available.gif" alt="Sin stock" class="stock-alert-gif">
      </div>
      <div id="stock-alert-list" class="stock-alert-list"></div>
      <button class="stock-alert-btn" onclick="irAlAlmacen()">
        Ver productos y abastecer <i class="fas fa-search"></i>
      </button>
    </div>
  </div>
</div>

<!-- Modal resumen caja -->
<div id="modal-caja-detalle" class="sys-modal" style="display:none">
  <div class="sys-modal-box">
    <div class="sys-modal-head" style="background:linear-gradient(135deg,#f59e0b,#d97706)">
      <h3 style="color:#fff"><i class="fas fa-cash-register" style="margin-right:8px"></i>Detalles caja <span id="mcd-titulo"></span></h3>
      <button class="modal-close" data-modal="modal-caja-detalle" style="color:#fff">✕</button>
    </div>
    <div class="sys-modal-body">
      <!-- Resumen tipo imagen de referencia -->
      <div id="mcd-resumen" class="mcd-resumen"></div>
      <!-- Movimientos -->
      <div class="sys-card-head" style="margin-top:14px;padding:10px 0 6px">
        <h3 style="font-size:13px"><i class="fas fa-list" style="color:var(--primary);margin-right:6px"></i>Movimientos detallados</h3>
      </div>
      <div class="table-wrap" style="max-height:220px;overflow-y:auto">
        <table>
          <thead><tr><th>Hora</th><th>Concepto</th><th>Tipo</th><th>Monto</th></tr></thead>
          <tbody id="mcd-movimientos"><tr><td colspan="4" class="empty-row">Cargando...</td></tr></tbody>
        </table>
      </div>
      <div class="form-actions" style="margin-top:14px">
        <button class="sys-btn sys-btn-outline" data-modal="modal-caja-detalle">Cerrar</button>
        <button class="sys-btn sys-btn-gold" id="mcd-btn-ticket"><i class="fas fa-print"></i> Imprimir ticket</button>
      </div>
    </div>
  </div>
</div>

<div id="sys-toast" class="sys-toast" style="display:none"></div>

