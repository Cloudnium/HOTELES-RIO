<!-- ================================================================
  PÁGINA: RESERVAS  (views/reservas.hbs)
================================================================ -->

<section class="hero hero-interior hero-reservas">
  <div class="hero-overlay"></div>
  <div class="hero-content hero-content-left fade-in">
    <span class="hero-eyebrow">Reserve su estadía</span>
    <h1 class="hero-title">Reservas</h1>
    <p class="hero-tagline">Proceso simple, experiencia memorable</p>
  </div>
  <nav class="breadcrumb">
    <a href="/">Inicio</a> <span>/</span> <span>Reservas</span>
  </nav>
</section>

<section class="reservas-section">
  <div class="section-container">

    <!-- Mensaje de éxito -->
    {{#if exito}}
    <div class="alert alert-success">
      <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      <div>
        <strong>¡Reserva recibida con éxito!</strong>
        <p>Nos contactaremos con usted a la brevedad para confirmar su reserva.<br>
        Habitación: <strong>{{datosReserva.habitacion}}</strong> —
        Fecha: <strong>{{datosReserva.fecha_reserva}}</strong> —
        Hora llegada: <strong>{{datosReserva.hora_llegada}}</strong></p>
      </div>
    </div>
    {{/if}}

    <div class="reservas-layout">

      <!-- FORMULARIO -->
      <div class="reservas-form-col">
        <form action="/reservas" method="POST" class="reservas-form" id="reservasForm" novalidate>

          <!-- PASO 1: Fechas -->
          <div class="form-step">
            <div class="form-step-header">
              <span class="step-num">01</span>
              <h3>Fechas y preferencias</h3>
            </div>
            <div class="form-grid-2">
              <div class="form-group">
                <label for="fecha_reserva">Fecha de reserva *</label>
                <input type="date" id="fecha_reserva" name="fecha_reserva" class="input-dark" required>
              </div>
              <div class="form-group">
                <label for="hora_llegada">Hora estimada de llegada *</label>
                <input type="time" id="hora_llegada" name="hora_llegada" class="input-dark" required>
              </div>
            </div>
            <div class="form-group">
              <label for="huespedes">Número de huéspedes *</label>
              <select id="huespedes" name="huespedes" class="input-dark" required>
                <option value="">Seleccione...</option>
                <option value="1">1 persona</option>
                <option value="2">2 personas</option>
              </select>
            </div>
          </div>

          <!-- PASO 2: Habitación -->
          <div class="form-step">
            <div class="form-step-header">
              <span class="step-num">02</span>
              <h3>Selección de habitación</h3>
            </div>
            <div class="habitacion-selector">
              {{#each habitaciones}}
              <label class="hab-option" for="hab-{{slug}}">
                <input type="radio" id="hab-{{slug}}" name="habitacion" value="{{nombre}}" required
                  {{#if @first}}checked{{/if}}>
                <div class="hab-option-content">
                  <img src="{{imagen}}" alt="{{imagenAlt}}"
                       onerror="this.style.display='none'">
                  <div class="hab-option-info">
                    <span class="hab-option-nombre">{{nombre}}</span>
                    <span class="hab-option-precio">S/. {{precio}} / 4 horas</span>
                  </div>
                  <span class="hab-option-check">✓</span>
                </div>
              </label>
              {{/each}}
            </div>
          </div>

          <!-- PASO 3: Datos -->
          <div class="form-step">
            <div class="form-step-header">
              <span class="step-num">03</span>
              <h3>Datos de los huéspedes</h3>
            </div>
            <div class="form-grid-2">
              <div class="form-group">
                <label for="nombre1">Nombre — Persona 1 *</label>
                <input type="text" id="nombre1" name="nombre1" class="input-dark"
                       placeholder="Nombres completos" required>
              </div>
              <div class="form-group">
                <label for="dni1">DNI — Persona 1 *</label>
                <input type="text" id="dni1" name="dni1" class="input-dark"
                       placeholder="N° de documento" maxlength="8" required>
              </div>
            </div>
            <!-- Persona 2 (se muestra si eligen 2 huéspedes) -->
            <div class="form-grid-2">
              <div class="form-group">
                <label for="telefono">Teléfono de contacto *</label>
                <input type="tel" id="telefono" name="telefono" class="input-dark" placeholder="+51 999 999 999">
              </div>
              <div class="form-group">
                <label for="email_cliente">Email (opcional)</label>
                <input type="email" id="email_cliente" name="email_cliente" class="input-dark" placeholder="correo@ejemplo.com">
              </div>
            </div>
            <div class="form-grid-2" id="persona2Row">
              <div class="form-group">
                <label for="nombre2">Nombre — Persona 2</label>
                <input type="text" id="nombre2" name="nombre2" class="input-dark"
                       placeholder="Nombres completos">
              </div>
              <div class="form-group">
                <label for="dni2">DNI — Persona 2</label>
                <input type="text" id="dni2" name="dni2" class="input-dark"
                       placeholder="N° de documento" maxlength="8">
              </div>
            </div>
          </div>

          <button type="submit" class="btn btn-gold btn-block btn-lg">
            Confirmar Reserva
            <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <p class="form-disclaimer">
            Al reservar acepta nuestra política de privacidad. Recibirá confirmación en breve.
          </p>

        </form>
      </div>

      <!-- SIDEBAR INFO -->
      <div class="reservas-sidebar">
        <div class="sidebar-card">
          <h4>Información de reserva</h4>
          <ul class="sidebar-info-list">
            <li>
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Máximo 2 personas por habitación
            </li>
            <li>
              <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
              Confirmación en menos de 24 hrs
            </li>
          </ul>
        </div>
        <div class="sidebar-card sidebar-contact">
          <h4>¿Tiene alguna duda?</h4>
          <p>Llámenos directamente para una atención personalizada</p>
          <!-- TELÉFONO — Edita aquí -->
          <a href="tel:+51951149420" class="btn btn-outline-dark btn-block">
            <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.7a16 16 0 0 0 6 6l.91-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.6 15z"/></svg>
            +51 951-149-420
          </a>
          <a href="/contacto" class="btn btn-outline-dark btn-block">Enviar mensaje</a>
        </div>
      </div>

    </div>
  </div>
</section>


{{#if exito}}
<script>
window.addEventListener('load',function(){
  setTimeout(function(){
    var datos={nombre:'{{datosReserva.nombre1}}',dni:'{{datosReserva.dni1}}',
      telefono:'{{datosReserva.telefono}}',habitacion:'{{datosReserva.habitacion}}',
      fecha:'{{datosReserva.fecha_reserva}}',hora:'{{datosReserva.hora_llegada}}',
      huespedes:'{{datosReserva.huespedes}}'};
    var win=window.open('','_blank','width=420,height=580');
    var fecha=datos.fecha?new Date(datos.fecha+'T12:00:00').toLocaleDateString('es-PE',{day:'2-digit',month:'long',year:'numeric'}):datos.fecha;
    win.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Reserva</title><style>@page{size:80mm auto;margin:4mm}*{margin:0;padding:0;box-sizing:border-box}body{font-family:"Courier New",Courier,monospace;font-size:11px;width:72mm;color:#000;background:#fff}.c{text-align:center}.b{font-weight:bold}.big{font-size:14px}.sm{font-size:9px}.ln{border-top:1px dashed #000;margin:4px 0}.logo{width:55mm;max-height:22mm;object-fit:contain;display:block;margin:0 auto 4px}table{width:100%;border-collapse:collapse}td{padding:2px 0;vertical-align:top}td.r{text-align:right}@media print{button{display:none!important}}</style></head><body>');
    win.document.write('<div class="c"><img src="/images/logos/logo.png" class="logo" onerror="this.style.display='none'"><div class="b big">HOTELES RIO</div><div class="sm">Au. Panamericana N 915, Sullana</div><div class="sm">Tel: +51 951-149-420</div></div>');
    win.document.write('<div class="ln"></div><div class="c b">CONFIRMACIÓN DE RESERVA</div><div class="ln"></div>');
    win.document.write('<table><tr><td class="b">Nombre:</td><td class="r">'+datos.nombre+'</td></tr><tr><td class="b">DNI:</td><td class="r">'+datos.dni+'</td></tr><tr><td class="b">Teléfono:</td><td class="r">'+(datos.telefono||'—')+'</td></tr><tr><td class="b">Huéspedes:</td><td class="r">'+datos.huespedes+'</td></tr></table>');
    win.document.write('<div class="ln"></div>');
    win.document.write('<table><tr><td class="b">Habitación:</td><td class="r">'+datos.habitacion+'</td></tr><tr><td class="b">Fecha reserva:</td><td class="r">'+fecha+'</td></tr><tr><td class="b">Hora de llegada:</td><td class="r">'+datos.hora+'</td></tr></table>');
    win.document.write('<div class="ln"></div><div class="c sm">Reserva tentativa. Le confirmaremos.</div><div class="c sm">Límite: 4 horas por habitación.</div><div class="ln"></div><div class="c sm">¡Gracias por elegir Hoteles Rio!</div><br><br>');
    win.document.write('<div style="text-align:center;margin-top:10px"><button onclick="window.print()" style="padding:8px 22px;font-size:13px;cursor:pointer;background:#1a1a1a;color:#fff;border:none;border-radius:4px;font-family:sans-serif">🖨 Imprimir</button></div>');
    win.document.write('</body></html>');win.document.close();
  },800);
});
</script>
{{/if}}

<script src="/js/reservas.js"></script>
