<!-- ================================================================
  PÁGINA: CONTACTO  (views/contacto.hbs)
================================================================ -->

<section class="hero hero-interior hero-contacto">
  <div class="hero-overlay"></div>
  <div class="hero-content hero-content-left fade-in">
    <span class="hero-eyebrow">Estamos para servirle</span>
    <h1 class="hero-title">Contacto</h1>
    <p class="hero-tagline">Hablemos, con gusto le atendemos</p>
  </div>
  <nav class="breadcrumb">
    <a href="/">Inicio</a> <span>/</span> <span>Contacto</span>
  </nav>
</section>

<section class="contacto-section">
  <div class="section-container">
    <div class="contacto-layout">

      <!-- FORMULARIO -->
      <div class="contacto-form-col slide-up">
        <span class="section-label">Deja tu mensaje</span>
        <h2 class="contacto-titulo">Escríbenos</h2>

        {{#if enviado}}
        <div class="alert alert-success">
          <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div>
            <strong>¡Mensaje enviado con éxito!</strong>
            <p>Nos comunicaremos con usted a la brevedad.</p>
          </div>
        </div>
        {{/if}}

        {{#if errorEnvio}}
        <div class="alert alert-error">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <div>
            <strong>Error al enviar</strong>
            <p>Verifique la configuración de correo en el archivo .env, o contáctenos por teléfono.</p>
          </div>
        </div>
        {{/if}}

        <form action="/contacto" method="POST" class="contacto-form" id="contactoForm" novalidate>
          <div class="form-group">
            <label for="nombre">Nombre completo *</label>
            <input type="text" id="nombre" name="nombre" class="input-light"
                   placeholder="Su nombre" required>
          </div>
          <div class="form-group">
            <label for="email">Correo electrónico *</label>
            <input type="email" id="email" name="email" class="input-light"
                   placeholder="correo@ejemplo.com" required>
          </div>
          <div class="form-group">
            <label for="asunto">Asunto</label>
            <input type="text" id="asunto" name="asunto" class="input-light"
                   placeholder="¿Sobre qué quiere consultar?">
          </div>
          <div class="form-group">
            <label for="mensaje">Mensaje *</label>
            <textarea id="mensaje" name="mensaje" class="input-light"
                      rows="5" placeholder="Escriba su mensaje aquí..." required></textarea>
          </div>
          <button type="submit" class="btn btn-gold">
            Enviar mensaje
            <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

      <!-- INFO CONTACTO -->
      <div class="contacto-info-col slide-up" style="animation-delay:0.2s">
        <div class="info-card-dark">
          <h3>Información de Contacto</h3>

          <div class="info-item">
            <div class="info-icon-box">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <span class="info-label">Dirección</span>
              <!-- DIRECCIÓN — Edita aquí -->
              <span class="info-val">Au. Panamericana N 915, Sullana 20103, Perú Referencia: Al lado de Shalom</span>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon-box">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.7a16 16 0 0 0 6 6l.91-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.6 15z"/></svg>
            </div>
            <div>
              <span class="info-label">Teléfono</span>
              <!-- TELÉFONO — Edita aquí -->
              <a href="tel:+51951149420" class="info-val info-link">+51 951-149-420</a>
            </div>
          </div>

          <div class="info-item">
            <div class="info-icon-box">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <span class="info-label">Sitio web</span>
              <!-- SITIO WEB — Edita aquí -->
              <a href="http://www.hoteles-rio.vercel.app" target="_blank" class="info-val info-link">www.hoteles-rio.vercel.app</a>
            </div>
          </div>

          <!-- MAPA ──────────────────────────────────────────────────
            Reemplaza el src del iframe con tu enlace de Google Maps
            Para obtenerlo: Google Maps → Compartir → Insertar mapa → Copia el src
          ────────────────────────────────────────────────────────── -->
          <div class="mapa-wrapper">
            <p class="mapa-label">Cómo llegar</p>
            <!-- REEMPLAZA el src con tu iframe de Google Maps real -->
            <iframe
              src="https://www.google.com/maps?q=-4.9252272,-80.696078&z=17&output=embed"
              width="100%"
              height="200"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de Hoteles Rio">
            </iframe>
          </div>

          <!-- HORARIOS — Edita aquí -->
          <div class="horarios">
            <p class="info-label" style="margin-bottom:10px">Horario de atención</p>
            <div class="horario-row"><span>Recepción</span><span>24 horas</span></div>
            <div class="horario-row"><span>Reservas telefónicas</span><span>8:00 - 22:00</span></div>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>
